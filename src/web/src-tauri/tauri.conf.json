{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "uzon-calc",
  "version": "0.1.0",
  "identifier": "com.uzoncloud.calc",
  "build": {
    "frontendDist": "../dist/spa",
    "devUrl": "http://localhost:3346",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "UzonCalc",
        "create": false,
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "config.toml"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
