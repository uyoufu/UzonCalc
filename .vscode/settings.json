{
  "python.analysis.extraPaths": ["./", "./src/core"],
  "cSpell.words": [
    "asctime",
    "astpretty",
    "BINOP",
    "cmpop",
    "coeff",
    "echart",
    "echarts",
    "elts",
    "finalbody",
    "fstring",
    "handcalc",
    "jobstores",
    "levelname",
    "mathml",
    "mathrm",
    "mathvariant",
    "mfenced",
    "mfrac",
    "mrow",
    "msqrt",
    "msub",
    "msup",
    "mtext",
    "Mult",
    "namedexpr",
    "numpy",
    "openpyxl",
    "orelse",
    "pandoc",
    "pyrs",
    "pytest",
    "redoc",
    "retcode",
    "rowspan",
    "subscriptify",
    "tauri",
    "uyoufu",
    "uzon",
    "uzoncalc",
    "xlwings"
  ],
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/*.code-search": true,
    "**/public": true,
    "*.lock": true
  },
  "python.testing.pytestArgs": ["core"],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "editor.tabSize": 2,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
  "python-envs.pythonProjects": [
    {
      "path": ".",
      "envManager": "ms-python.python:venv",
      "packageManager": "ms-python.python:pip"
    }
  ],
  "rust-analyzer.linkedProjects": ["ui/web/src-tauri/Cargo.toml"],
  "rust-analyzer.server.extraEnv": {
    "HTTP_PROXY": "http://127.0.0.1:7890",
    "HTTPS_PROXY": "http://127.0.0.1:7890",
    "ALL_PROXY": "http://127.0.0.1:7890"
  },

  "rust-analyzer.cargo.extraEnv": {
    "HTTP_PROXY": "http://127.0.0.1:7890",
    "HTTPS_PROXY": "http://127.0.0.1:7890",
    "ALL_PROXY": "http://127.0.0.1:7890"
  }
}
